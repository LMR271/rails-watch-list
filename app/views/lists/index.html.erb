<br><h1>Your Watch Lists</h1>

  <div class="lists-grid">
    <% @lists.each do |list| %>
      <% photo_url = list.photo.attached? ? cl_image_path(list.photo.key) : image_url("istockphoto-1007557230-612x612.jpg") %>
      <%= link_to list_path(list), class: "card-category",
          style: "background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('#{photo_url}')" do %>
        <h2 class="card-category-name"><%= list.name %></h2>
      <% end %>
    <% end %>
  </div>

<%= link_to "New list", new_list_path, class: "btn btn-flat"%>
